# Supabase — fill these in Vercel's Environment Variables, not here.
# Public (browser-readable) — used by the dashboard frontend for read-only queries:
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (NEVER exposed to the browser) — used by webhook handlers to write:
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook shared secrets — appended to each handler URL as ?token=... (and, for
# Lemlist, also accepted as the in-body `secret` field).
INSTANTLY_WEBHOOK_SECRET=your-instantly-webhook-secret
HEYREACH_WEBHOOK_SECRET=your-heyreach-webhook-secret
JUSTCALL_WEBHOOK_SECRET=your-justcall-webhook-secret
LEMLIST_WEBHOOK_SECRET=your-lemlist-webhook-secret

# Zoho CRM (US datacenter) — read-only pull sync at /api/sync/zoho.
ZOHO_CLIENT_ID=your-zoho-client-id
ZOHO_CLIENT_SECRET=your-zoho-client-secret
ZOHO_REFRESH_TOKEN=your-zoho-refresh-token
# Protects the sync route for manual/external triggering (?token=...).
ZOHO_SYNC_SECRET=your-zoho-sync-secret
# Set this so Vercel Cron can authenticate to the sync route via its
# automatic `Authorization: Bearer <CRON_SECRET>` header.
CRON_SECRET=your-cron-secret
